{
  "name": "portal-shell",
  "version": "1.6.0-snapshot",
  "overrides": {
    "ng-mocks": {
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core",
      "@angular/forms": "$@angular/forms",
      "@angular/platform-browser": "$@angular/platform-browser",
      "@angular/platform-browser-dynamic": "$@angular/platform-browser-dynamic",
      "rxjs": "$rxjs",
      "zone.js": "$zone.js"
    }
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "build-dev": "ng build --configuration development",
    "clean-cache": "rimraf .angular/cache && echo Cache cleared - next build will be slower but clean",
    "build-fresh": "npm run clean-cache && npm run build",
    "watch": "ng build --watch --configuration development",
    "test-local": "ng test --karma-config karma.conf.js --watch",
    "test": "ng test --karma-config karma.single-run.conf.js",
    "test:coverage": "ng test --karma-config karma.coverage.conf.js",
    "docker": "docker build -t europe-west3-docker.pkg.dev/gematik-all-infra-prod/demis-dev/portal-shell:latest .",
    "build:single-spa:portal-shell": "ng build portal-shell --configuration development",
    "serve:single-spa:portal-shell": "ng s --project portal-shell --disable-host-check --port 4200 --live-reload false"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.4",
    "@angular/cdk": "21.2.2",
    "@angular/common": "21.2.4",
    "@angular/compiler": "21.2.4",
    "@angular/core": "21.2.4",
    "@angular/forms": "21.2.4",
    "@angular/material": "21.2.2",
    "@angular/material-luxon-adapter": "21.2.2",
    "@angular/platform-browser": "21.2.4",
    "@angular/platform-browser-dynamic": "21.2.4",
    "@angular/router": "21.2.4",
    "@auth0/angular-jwt": "5.2.0",
    "@gematik/demis-portal-core-library": "3.1.0",
    "@gematik/demis-portal-theme-library": "1.1.2",
    "@ngrx/signals": "21.0.1",
    "angular-auth-oidc-client": "21.0.1",
    "bootstrap": "5.3.8",
    "import-map-overrides": "6.1.0",
    "marked": "17.0.1",
    "material-icons": "1.13.14",
    "ngx-logger": "5.0.12",
    "ngx-toastr": "20.0.5",
    "rxjs": "7.8.2",
    "single-spa": "6.0.3",
    "systemjs": "6.15.1",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.2.0",
    "@angular-eslint/eslint-plugin": "21.2.0",
    "@angular-eslint/eslint-plugin-template": "21.2.0",
    "@angular-eslint/schematics": "21.2.0",
    "@angular-eslint/template-parser": "21.2.0",
    "@angular/build": "21.2.2",
    "@angular/cli": "21.2.2",
    "@angular/compiler-cli": "21.2.4",
    "@types/jasmine": "6.0.0",
    "@types/luxon": "3.7.1",
    "@types/node": "25.2.2",
    "@types/systemjs": "6.15.4",
    "@typescript-eslint/eslint-plugin": "8.55.0",
    "@typescript-eslint/parser": "8.55.0",
    "eslint": "9.39.2",
    "jasmine-core": "5.9.0",
    "jasmine-spec-reporter": "7.0.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-coverage-istanbul-reporter": "3.0.3",
    "karma-firefox-launcher": "2.1.3",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "karma-junit-reporter": "2.0.1",
    "karma-sonarqube-unit-reporter": "0.0.23",
    "ng-mocks": "14.15.1",
    "rimraf": "6.1.2",
    "typescript": "5.9.3",
    "webpack": "5.105.1"
  }
}
